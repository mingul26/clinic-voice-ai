# ─── Bolna Voice AI ───────────────────────────────────────────────────────────
# Get these from https://app.bolna.dev → Settings → API Keys
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_AGENT_ID=your_bolna_agent_id_here

# ─── Database (only needed for local dev outside Docker) ──────────────────────
DB_URL=jdbc:postgresql://localhost:5432/clinic
DB_USER=clinic
DB_PASS=clinic

# ─── Frontend (Vite) — set at build time for non-proxied deployments ──────────
# Leave empty when running behind nginx proxy (docker-compose default)
# Set to your Railway backend URL when deploying to Vercel
VITE_API_URL=
